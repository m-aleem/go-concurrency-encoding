package goencodingtest

import goencoding.*

net TestAsync physical "tcp-127.0.0.1:9999"{

	node ChannelFactory logical "channel_factory"{
	    println("[ChannelFactory] Initialized")
	    var Integer numChans = 0
	    
		// Main loop that listens for new channel requests
	    while(true) {
	        println("[ChannelFactory] Waiting for channel create requests...")
	
	        in("make_chan", var Object returnTag, var String chanType, var Integer capacity, var Object msgType, var Locality requester)@self
	        numChans++
	        println("[ChannelFactory] Request for channel of type chanType " + chanType)


            val Locality newChan = newloc()

            // Evaluate (kick off) channel process
            if(chanType == "async"){
                eval(new async_channel(capacity))@newChan
            }
            else if(chanType == "sync"){
                eval(new sync_channel())@newChan
            }
            
            // Put channel capacity and message type in its tuple space, for easy read access
        	out("capacity", capacity)@newChan
            out("msgType", msgType)@newChan

            // Store in registry
            out("chan_registered", numChans, chanType, capacity, msgType, newChan)@self
            println("[ChannelFactory] Stored channel in registry: (" + numChans + ": " + newChan + ")")

            // Send to requester
            out("new_chan", returnTag, chanType, newChan)@requester
		}
	
	}   
    
    node NodeA {
        
        val Locality returnTag = self


        println("[NodeA] Requesting channel... " )
        eval(new async_new(channel_factory, 3, Integer, returnTag))@self
        in(returnTag, var Locality ch)@self
        println("[NodeA] Got channel " + ch)
        
        out(ch)@node_b
        out(ch)@node_c
        
    }

    node NodeB logical "node_b"{
    	in(var Locality ch)@self
        println("[Node B] Got channel " + ch)
        
        eval(new async_send(ch, 1))@self
        eval(new async_send(ch, 2))@self
        eval(new async_send(ch, 3))@self
        eval(new async_send(ch, 4))@self
        eval(new async_send(ch, 5))@self

    }

    node NodeC logical "node_c" {
    	in(var Locality ch)@self
        println("[Node C] Got channel " + ch)
        
        eval(new async_recv(ch, self))@self
        in(self, var Integer msg)@self
        println("[Node C] Recv message " + msg)

        eval(new async_recv(ch, self))@self
        in(self, var Integer msg)@self
        println("[Node C] Recv message " + msg)

        eval(new async_recv(ch, self))@self
        in(self, var Integer msg)@self
        println("[Node C] Recv message " + msg)

        eval(new async_recv(ch, self))@self
        in(self, var Integer msg)@self
        println("[Node C] Recv message " + msg)

        eval(new async_recv(ch, self))@self
        in(self, var Integer msg)@self
        println("[Node C] Recv message " + msg)

    }
}