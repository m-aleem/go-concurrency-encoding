package goencodingtest

import goencoding.*

net TestAsync physical "localhost:9999"{


    node ChannelFactory logical "channel_factory"{
        println("[ChannelFactory] Initialized")

            while(true) {
                println("[ChannelFactory] Waiting for channel create requests...")

                in("make_chan", var String chanType, var String chanName, var Locality requester)@self
                println("[ChannelFactory] Request for channel: " + chanName + " (" + chanType + ")")

                // Check if the channel already exists
                // Use Object for the Locality since we get a class error otherwise
                var String otherChanType = ""
                if(chanType == "async"){
                    otherChanType = "sync"
                }
                else if(chanType == "sync"){
                    otherChanType = "async"
                }

                val boolean exists = read_nb("chan_registered", chanType, chanName, var Object locObj)@self
                val boolean existsOther = read_nb("chan_registered", otherChanType, chanName, var Object locObj)@self

                if(existsOther) {
                    println("[ChannelFactory] ERROR channel " + chanName + " already exists as " + otherChanType)
                }
                else if (exists) {
                    // Read from registry
                    read_nb("chan_registered", chanType, chanName, var Locality existingChan)@self
                    println("[ChannelFactory] Found existing channel: " + existingChan)

                    // Send to requester
                    out("new_chan", chanType, chanName, existingChan)@requester

                } else {
                    println("[ChannelFactory] Creating new channel for: " + chanName)
                    val Locality newChan = newloc()

                    // Evaluate channel process
                    if(chanType == "async"){
                        eval(new async_channel(chanName))@newChan
                    }
                    else if(chanType == "sync"){
                        eval(new sync_channel(chanName))@newChan
                    }

                    // Store in registry
                    out("chan_registered", chanType, chanName, newChan)@self
                    println("[ChannelFactory] Stored channel in registry: (" + chanName + ", " + newChan + ")")

                    // Send to requester
                    out("hello")@requester
                    out("new_chan", chanType, chanName, newChan)@requester
                }
            }
    }


    node NodeA {
        val String chanName = "channelX"
        val Locality returnTag = self


        println("[NodeA] Requesting channel... " + chanName)
        eval(new async_new(channel_factory, chanName, returnTag))@self
        in(returnTag, var Locality ch)@self
        println("[NodeA] Got channel " + ch)

        println("[NodeA] Requesting channel... " + chanName)
        eval(new async_new(channel_factory, chanName, returnTag))@self
        in(returnTag, var Locality ch2)@self
        println("[NodeA] Got channel " + ch2 + ", should be the same as above (" + (ch2==ch) + ")")

//        println("[NodeA] Requesting channel... " + chanName)
//        eval(new sync_new(channel_factory, chanName, returnTag))@self
//        in(returnTag, var Locality ch3)@self
//        println("[NodeA] ERROR this should not print...")

        var msg = "hello"
        eval(new async_send(ch, msg))@self
        println("[NodeA] Sent message " + msg)
    }


    node NodeB {
        val String chanName = "channelX"
        val Locality returnTag = self

        eval(new async_new(channel_factory, chanName, returnTag))@self
        in(returnTag, var Locality ch)@self
        println("[NodeB] Got channel " + ch)

        eval(new async_recv(ch, returnTag))@self
        in(returnTag, var Object msg)@self
        println("[NodeB] Got message " + msg)

    }

    // FIXME -- test idea, try swapping calls from @self to the other node and see if this still works!


}